# Validated by @fomo/env at boot — a missing/invalid var fails fast.
# Copy to .env and fill in. Never commit real keys.

# --- core ---
CORS_ORIGIN=http://localhost:3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/fomo

# --- server-only secrets (./server) — never reach the browser ---
BIRDEYE_API_KEY=
ALCHEMY_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/your-alchemy-key
JUPITER_API_KEY=
PRIVY_APP_SECRET=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- client-safe (./web) — shipped to the browser ---
NEXT_PUBLIC_PRIVY_APP_ID=
